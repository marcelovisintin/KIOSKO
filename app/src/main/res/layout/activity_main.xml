<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_kiosk_gradient"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/pinLoginContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_panel"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_lock_lock"
                app:tint="@color/kiosko_primary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="@string/pin_title"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="@color/kiosko_text"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:gravity="center"
                android:text="@string/pin_subtitle"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/kiosko_muted" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/loginUsernameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/login_username_hint"
                    android:imeOptions="actionDone"
                    android:inputType="textPersonName"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:id="@+id/pinDotsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:orientation="horizontal">

                <View
                    android:id="@+id/pinDot1"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_pin_dot_empty" />

                <View
                    android:id="@+id/pinDot2"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_pin_dot_empty" />

                <View
                    android:id="@+id/pinDot3"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_pin_dot_empty" />

                <View
                    android:id="@+id/pinDot4"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_pin_dot_empty" />
            </LinearLayout>

            <TextView
                android:id="@+id/pinErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/pin_incorrect"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="@color/kiosko_error"
                android:visibility="gone" />

            <GridLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:columnCount="3">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pinKey1"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="84dp"
                    android:layout_height="64dp"
                    android:layout_margin="6dp"
                    android:text="1"
                    android:textColor="@color/kiosko_text"
                    android:textSize="20sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pinKey2"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="84dp"
                    android:layout_height="64dp"
                    android:layout_margin="6dp"
                    android:text="2"
                    android:textColor="@color/kiosko_text"
                    android:textSize="20sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pinKey3"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="84dp"
                    android:layout_height="64dp"
                    android:layout_margin="6dp"
                    android:text="3"
                    android:textColor="@color/kiosko_text"
                    android:textSize="20sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pinKey4"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="84dp"
                    android:layout_height="64dp"
                    android:layout_margin="6dp"
                    android:text="4"
                    android:textColor="@color/kiosko_text"
                    android:textSize="20sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pinKey5"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="84dp"
                    android:layout_height="64dp"
                    android:layout_margin="6dp"
                    android:text="5"
                    android:textColor="@color/kiosko_text"
                    android:textSize="20sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pinKey6"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="84dp"
                    android:layout_height="64dp"
                    android:layout_margin="6dp"
                    android:text="6"
                    android:textColor="@color/kiosko_text"
                    android:textSize="20sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pinKey7"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="84dp"
                    android:layout_height="64dp"
                    android:layout_margin="6dp"
                    android:text="7"
                    android:textColor="@color/kiosko_text"
                    android:textSize="20sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pinKey8"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="84dp"
                    android:layout_height="64dp"
                    android:layout_margin="6dp"
                    android:text="8"
                    android:textColor="@color/kiosko_text"
                    android:textSize="20sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pinKey9"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="84dp"
                    android:layout_height="64dp"
                    android:layout_margin="6dp"
                    android:text="9"
                    android:textColor="@color/kiosko_text"
                    android:textSize="20sp" />

                <View
                    android:layout_width="84dp"
                    android:layout_height="64dp"
                    android:layout_margin="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pinKey0"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="84dp"
                    android:layout_height="64dp"
                    android:layout_margin="6dp"
                    android:text="0"
                    android:textColor="@color/kiosko_text"
                    android:textSize="20sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pinKeyBackspace"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="84dp"
                    android:layout_height="64dp"
                    android:layout_margin="6dp"
                    android:contentDescription="@string/pin_backspace"
                    android:text="DEL"
                    android:textColor="@color/kiosko_text"
                    android:textSize="18sp" />
            </GridLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/launcherContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_panel"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/launcherUserNameText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/kiosk_header_title"
                        android:textAppearance="?attr/textAppearanceTitleLarge"
                        android:textColor="@color/kiosko_text"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/dateTimeText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/kiosk_header_subtitle"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/kiosko_muted"
                        tools:text="10:30 - Tue 24 Feb" />
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textStyle="bold"
                tools:text="Modo kiosco activo (device owner)." />

            <TextView
                android:id="@+id/lockTaskStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                tools:text="Lock task activo." />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/userSwitchAccountButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/user_switch_account"
                android:textAllCaps="false" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/allowed_apps_title"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="@color/kiosko_muted"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/appsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="8dp"
                tools:listitem="@layout/item_allowed_app" />

            <TextView
                android:id="@+id/emptyText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/no_allowed_apps"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/kiosko_muted"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/bottomInfoText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_bottom_pill"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/kiosko_muted"
            tools:text="4 apps disponibles - dispositivo protegido" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/adminContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="18dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_panel"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_panel_title"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:textColor="@color/kiosko_text"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/admin_panel_subtitle"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/kiosko_muted" />

                <TextView
                    android:id="@+id/adminModeSourceText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    tools:text="Admin mode remoto: inactivo" />

                <TextView
                    android:id="@+id/adminPolicyStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    tools:text="Modo kiosco activo (device owner)." />

                <TextView
                    android:id="@+id/adminLockStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    tools:text="Lock task inactivo." />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/adminApplyPoliciesButton"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/admin_apply_policies"
                    android:textAllCaps="false" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/admin_allowed_packages_title"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/kiosko_muted"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/adminAllowedPackagesText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_glass_panel"
                android:lineSpacingExtra="2dp"
                android:padding="14dp"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/kiosko_text"
                tools:text="com.android.chrome&#10;com.schneider.kiosko" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/admin_users_title"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/kiosko_muted"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/adminUserSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_glass_panel"
                android:padding="8dp" />

            <TextView
                android:id="@+id/adminNoUsersText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/admin_no_users"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/kiosko_muted"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/adminNewUserNameInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/admin_user_name_hint"
                        android:imeOptions="actionNext"
                        android:inputType="textPersonName"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="112dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/adminNewUserPinInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/admin_user_pin_hint"
                        android:imeOptions="actionDone"
                        android:inputType="numberPassword"
                        android:maxLength="4"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/adminAddUserButton"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/admin_add_user"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/adminDeleteUserButton"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/admin_delete_user"
                    android:textAllCaps="false" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/admin_web_links_title"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/kiosko_muted"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/adminNewWebNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/admin_web_name_hint"
                    android:imeOptions="actionNext"
                    android:inputType="textCapSentences"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/adminNewWebUrlInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/admin_web_url_hint"
                    android:imeOptions="actionDone"
                    android:inputType="textUri"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/adminAddWebLinkButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/admin_add_web_link"
                android:textAllCaps="false" />

            <TextView
                android:id="@+id/adminNoWebLinksText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/admin_no_web_links"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/kiosko_muted"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/adminWebLinksContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_glass_panel"
                android:orientation="vertical"
                android:padding="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/admin_user_apps_title"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/kiosko_muted"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/adminNoAssignableAppsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/admin_no_assignable_apps"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/kiosko_muted"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/adminUserAppsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_glass_panel"
                android:orientation="vertical"
                android:padding="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/adminLogoutButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/admin_logout"
                android:textAllCaps="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/adminExitKioskButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/admin_exit_kiosk"
                android:textAllCaps="false" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
